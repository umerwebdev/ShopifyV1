{% doc %}
  @prompt
    i want you to generate a subscrubtion plan having three cards 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-subscription-plans-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-subscription-plans__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-subscription-plans__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-subscription-plans__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-subscription-plans__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-subscription-plan-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 32px 24px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .ai-subscription-plan-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-subscription-plan-card-{{ ai_gen_id }}--featured {
    border-color: {{ block.settings.featured_border_color }};
    border-width: {{ block.settings.featured_border_thickness }}px;
  }

  .ai-subscription-plan-badge-{{ ai_gen_id }} {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: {{ block.settings.badge_background_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-subscription-plan-name-{{ ai_gen_id }} {
    font-size: 24px;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-subscription-plan-price-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-subscription-plan-amount-{{ ai_gen_id }} {
    font-size: 48px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
    line-height: 1;
  }

  .ai-subscription-plan-currency-{{ ai_gen_id }} {
    font-size: 24px;
    vertical-align: super;
  }

  .ai-subscription-plan-period-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.card_text_color }};
    opacity: 0.7;
    margin-top: 8px;
  }

  .ai-subscription-plan-description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.card_text_color }};
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .ai-subscription-plan-features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    text-align: left;
  }

  .ai-subscription-plan-feature-{{ ai_gen_id }} {
    padding: 12px 0;
    color: {{ block.settings.card_text_color }};
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-subscription-plan-feature-{{ ai_gen_id }}::before {
    content: "✓";
    color: {{ block.settings.checkmark_color }};
    font-weight: 700;
    font-size: 18px;
    flex-shrink: 0;
  }

  .ai-subscription-plan-button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    padding: 14px 28px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-subscription-plan-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
  }

  .ai-subscription-plan-card-{{ ai_gen_id }}--featured .ai-subscription-plan-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.featured_button_background_color }};
    color: {{ block.settings.featured_button_text_color }};
  }

  .ai-subscription-plan-card-{{ ai_gen_id }}--featured .ai-subscription-plan-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.featured_button_hover_background_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-subscription-plans__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-subscription-plans-{{ ai_gen_id }} {
      width: 100%;
    }
  }

  @media screen and (min-width: 990px) and (max-width: 1200px) {
    .ai-subscription-plans__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }
{% endstyle %}

<subscription-plans-{{ ai_gen_id }} class="ai-subscription-plans-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-subscription-plans__header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-subscription-plans__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <div class="ai-subscription-plans__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>

  <div class="ai-subscription-plans__container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign plan_enabled_key = 'plan_' | append: i | append: '_enabled'
        assign plan_name_key = 'plan_' | append: i | append: '_name'
        assign plan_price_key = 'plan_' | append: i | append: '_price'
        assign plan_period_key = 'plan_' | append: i | append: '_period'
        assign plan_description_key = 'plan_' | append: i | append: '_description'
        assign plan_features_key = 'plan_' | append: i | append: '_features'
        assign plan_button_text_key = 'plan_' | append: i | append: '_button_text'
        assign plan_button_link_key = 'plan_' | append: i | append: '_button_link'
        assign plan_featured_key = 'plan_' | append: i | append: '_featured'
        assign plan_badge_text_key = 'plan_' | append: i | append: '_badge_text'

        assign plan_enabled = block.settings[plan_enabled_key]
        assign plan_name = block.settings[plan_name_key]
        assign plan_price = block.settings[plan_price_key]
        assign plan_period = block.settings[plan_period_key]
        assign plan_description = block.settings[plan_description_key]
        assign plan_features = block.settings[plan_features_key]
        assign plan_button_text = block.settings[plan_button_text_key]
        assign plan_button_link = block.settings[plan_button_link_key]
        assign plan_featured = block.settings[plan_featured_key]
        assign plan_badge_text = block.settings[plan_badge_text_key]
      %}

      {% if plan_enabled %}
        <div class="ai-subscription-plan-card-{{ ai_gen_id }} {% if plan_featured %}ai-subscription-plan-card-{{ ai_gen_id }}--featured{% endif %}">
          {% if plan_featured and plan_badge_text != blank %}
            <div class="ai-subscription-plan-badge-{{ ai_gen_id }}">{{ plan_badge_text }}</div>
          {% endif %}

          {% if plan_name != blank %}
            <h3 class="ai-subscription-plan-name-{{ ai_gen_id }}">{{ plan_name }}</h3>
          {% endif %}

          <div class="ai-subscription-plan-price-{{ ai_gen_id }}">
            <div class="ai-subscription-plan-amount-{{ ai_gen_id }}">
              <span class="ai-subscription-plan-currency-{{ ai_gen_id }}">{{ block.settings.currency_symbol }}</span>{{ plan_price }}
            </div>
            {% if plan_period != blank %}
              <div class="ai-subscription-plan-period-{{ ai_gen_id }}">{{ plan_period }}</div>
            {% endif %}
          </div>

          {% if plan_description != blank %}
            <div class="ai-subscription-plan-description-{{ ai_gen_id }}">{{ plan_description }}</div>
          {% endif %}

          {% if plan_features != blank %}
            {% assign features_array = plan_features | split: '|' %}
            <ul class="ai-subscription-plan-features-{{ ai_gen_id }}">
              {% for feature in features_array %}
                <li class="ai-subscription-plan-feature-{{ ai_gen_id }}">{{ feature | strip }}</li>
              {% endfor %}
            </ul>
          {% endif %}

          {% if plan_button_text != blank %}
            <a href="{{ plan_button_link }}" class="ai-subscription-plan-button-{{ ai_gen_id }}">
              {{ plan_button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</subscription-plans-{{ ai_gen_id }}>

<script>
  (function() {
    class SubscriptionPlans{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const buttons = this.querySelectorAll('.ai-subscription-plan-button-{{ ai_gen_id }}');
        buttons.forEach(button => {
          if (!button.getAttribute('href') || button.getAttribute('href') === '') {
            button.setAttribute('role', 'button');
            button.setAttribute('tabindex', '0');
          }
        });
      }
    }

    customElements.define('subscription-plans-{{ ai_gen_id }}', SubscriptionPlans{{ ai_gen_id }});
  })();
</script>

